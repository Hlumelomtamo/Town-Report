# ─────────────────────────────────────────────
#  TownReport — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# Server
PORT=3000

# OpenAI — get your key at https://platform.openai.com
OPENAI_API_KEY=YouShouldNotSeeThisKeyInTheRepoButHereItIsAnywayBecauseThisIsAnExampleAndNotTheRealKey

# Supabase — get these from your project's Settings > API
SUPABASE_URL=https://maybeItIsMine.supabase.co
SUPABASE_ANON_KEY=psych,IGotYou,ButDontStealMyKey

# Optional: Twilio for WhatsApp/SMS alerts
# Get credentials at https://twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_FROM=+1234567890       # Your Twilio number
TWILIO_PHONE_TO=+0987654321         # Admin's phone number

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500
